# Server Configuration
PORT
NODE_ENV # dev,production

# Google OAuth Configuration
GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET

# Session Configuration
SESSION_SECRET

#JWT Configuration
JWT_SECRET
JWT_EXPIRE

# Client URL (for CORS and redirects)
CLIENT_URL

# Blockchain & Smart Contract Configurations
NETWORK
RPC_URL
MARKETPLACE_FEE_MANAGER_ADDRESS
NFT_COLLECTION_FACTORY_ADDRESS
MARKETPLACE_ADDRESS

# Subgraph Configuration
SUBGRAPH_URL # http://localhost:8000/subgraphs/name/nftmarketplace
SUBGRAPH_POLL_INTERVAL # 5000 (milliseconds)

#Database Configuration
DEV_DB_HOST
DEV_DB_PORT
DEV_DB_NAME
DEV_DB_USERNAME
DEV_DB_PASSWORD
SSL_REJECT_UNAUTHORIZED
SSL_CA # Optional for custom CA

# Algolia Configuration
ALGOLIA_APP_ID
ALGOLIA_WRITE_API_KEY
ALGOLIA_NFT_INDEX_NAME # Name of the index (e.g., "nfts_index" or what you prefer)
ALGOLIA_INDEX_NAME_2 # if you have multiple indices
ALGOLIA_ADMIN_API_KEY # Optional for admin operations

# Socket.IO & Realtime Configuration
CLIENT_URL # For CORS and Socket.IO origin

# Cron Jobs Configuration
ENABLE_CRON_JOBS # true/false
ENABLE_DAILY_DIGEST # true/false
TIMEZONE # UTC, Asia/Ho_Chi_Minh, etc.

# Rate Limiting
RATE_LIMIT_WINDOW_MS # 900000 (15 minutes)
RATE_LIMIT_MAX # 100
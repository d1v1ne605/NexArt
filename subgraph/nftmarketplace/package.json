  "scripts": {
    "update-networks": "node -e \"require('./update-network.js').main()\"",
    "update-abis": "node -e \"require('./update-network.js').copyABIs()\"",
    "update-networks-json": "node -e \"require('./update-network.js').updateNetworkJson()\"",
    "codegen": "graph codegen",
    "build": "graph build",
    "deploy": "graph deploy --node https://api.studio.thegraph.com/deploy/ nftmarketplace",
